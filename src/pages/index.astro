---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Révisions Master IFMK">
  <div id="home">
    <div class="home-hero">
      <h1>Révisions Master IFMK</h1>
      <p>Sélectionnez une UE pour commencer</p>
    </div>
    <div class="ue-grid">
      <a href="/ue23" class="ue-card ue-card--23">
        <div class="ue-icon">📖</div>
        <div class="ue-label">UE 23</div>
        <div class="ue-name">Gérontologie & PTG</div>
        <div class="ue-desc">Fragilité, chutes, sarcopénie, PTG — Cours, flashcards, QCM</div>
      </a>
      <a href="${base}/ue18" class="ue-card ue-card--18">
        <div class="ue-icon">🏥</div>
        <div class="ue-label">UE 18</div>
        <div class="ue-name">Gériatrie — Révisions</div>
        <div class="ue-desc">Chutes, désadaptation, dénutrition, oncologie, soins palliatifs</div>
      </a>
    </div>
  </div>
</Layout>

<style>
  #home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background: var(--bg);
  }

  .home-hero {
    text-align: center;
    margin-bottom: 48px;
  }
  .home-hero h1 {
    font-size: 28px;
    font-weight: 800;
    color: var(--tx);
    margin-bottom: 8px;
  }
  .home-hero p {
    color: var(--mu);
    font-size: 15px;
  }

  .ue-grid {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ue-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: var(--s1);
    border: 2px solid var(--bd);
    border-radius: 16px;
    padding: 32px 28px;
    width: 280px;
    text-decoration: none;
    color: var(--tx);
    transition: border-color .2s, transform .15s;
  }
  .ue-card:hover { transform: translateY(-4px); }
  .ue-card--23:hover { border-color: var(--c1); }
  .ue-card--18:hover { border-color: var(--c2); }

  .ue-icon { font-size: 40px; }
  .ue-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    color: var(--mu);
    text-transform: uppercase;
  }
  .ue-name { font-size: 17px; font-weight: 700; text-align: center; }
  .ue-desc { font-size: 12px; color: var(--mu); text-align: center; line-height: 1.5; }

  .ue-card--23 .ue-name { color: var(--c1); }
  .ue-card--18 .ue-name { color: var(--c2); }
</style>
